# Google Drive Folder & Authentication Configuration
# Rename this file to .env.local and populate either Option A or Option B.

# The ID of the Google Drive folder where uploads should be saved.
# Example: https://drive.google.com/drive/folders/1A2B3C4D5E6F7G8H9I0J (ID is 1A2B3C4D5E6F7G8H9I0J)
GOOGLE_DRIVE_FOLDER_ID=your-google-drive-folder-id-here

# ====================================================================
# OPTION A: Google OAuth 2.0 (Recommended for Personal @gmail.com accounts)
# ====================================================================
# Avoids the "Service Accounts do not have storage quota" error by uploading
# directly on behalf of your personal Google Account.
GOOGLE_CLIENT_ID=your-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-oauth-client-secret
GOOGLE_REFRESH_TOKEN=1//your-oauth-refresh-token-here

# ====================================================================
# OPTION B: Service Account (Recommended for Google Workspace/Shared Drives)
# ====================================================================
# Note: Folders must be shared with the Service Account email as Editor.
# Note: Uploading to standard personal folders will fail with 403 quota limits.
# Use Shared Drives for Service Accounts!
GOOGLE_CLIENT_EMAIL=your-service-account-email@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYourPrivateKeyHere\n-----END PRIVATE KEY-----\n"
